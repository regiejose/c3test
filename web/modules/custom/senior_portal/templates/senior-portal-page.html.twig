<div class="container mx-auto py-10">
  <div class="grid md:grid-cols-3 gap-6">
    {% for item in items %}
      <div class="border rounded-lg p-4 shadow">
        <h2 class="text-xl font-semibold">
          {{ item.title }}
        </h2>
        <div class="text-body">
          {{ item.description }}
        </div>
      </div>
    {% endfor %}
  </div>
</div>